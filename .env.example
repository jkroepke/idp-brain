# Local disposable PostgreSQL settings for docker compose.
# These values are safe development defaults only and are not production secrets.
POSTGRES_DB=idp_brain
POSTGRES_USER=idp_brain
POSTGRES_PASSWORD=idp_brain
IDP_BRAIN_POSTGRES_PORT=55432

# idp-brain application settings.
# All values are safe for local development and CI.
IDP_BRAIN_DATABASE_URL=postgresql+psycopg://idp_brain:idp_brain@localhost:55432/idp_brain
IDP_BRAIN_LOG_LEVEL=INFO
IDP_BRAIN_CONFIG_DIR=config
IDP_BRAIN_CACHE_DIR=.idp-brain-cache
IDP_BRAIN_EMBEDDING_PROVIDER=mock
IDP_BRAIN_EXTERNAL_MODEL_CALLS_ENABLED=false
